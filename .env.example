# Markdown Editor Configuration
# All settings are optional - the app works with defaults

# REPOS_PATH - Where to store markdown files (defaults to ./repos)
# Supports: absolute (/path/to/repos), relative (../repos), or tilde (~/repos)
# REPOS_PATH=../repos

# ALLOWED_EXTENSIONS - Comma-separated list of editable file extensions
# Defaults to: md,markdown
# ALLOWED_EXTENSIONS=md,markdown,txt,html

# BASE_PATH - If the app is served from a subdirectory, set this explicitly
# Example (site root): BASE_PATH=/
# Example (subdirectory): BASE_PATH=/mdeditor
# Example (direct public path): BASE_PATH=/public

# Admin credentials for login (optional)
# If both are omitted, login is disabled and the app is open.
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=your-secure-password-here
